PORT=8080
LOG_LEVEL=debug

# --- Ollama ---
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
CHAT_MODEL=llama3.2

# --- Vector Store ---
# Options: memory, weaviate, chromem
VECTOR_STORE=weaviate
WEAVIATE_HOST=weaviate:8080
WEAVIATE_SCHEME=http
# CHROMEM_DIR=./data/chromem  # for chromem store

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DEFAULT_K=5

# --- Advanced Features (all optional, disabled by default) ---
CONTEXTUAL_CHUNKING=false     # Enrich chunks with document context via LLM
CORRECTIVE_RAG=false          # Evaluate retrieval quality, rephrase & re-retrieve if poor
RERANKING=false               # LLM-based reranking of search results
REDIS_URL=                    # Enable query response cache (empty = disabled)
CACHE_TTL=10m                 # Cache TTL

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
